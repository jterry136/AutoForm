# ─── AutoForm environment ────────────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.
# These are validated at startup by src/lib/env.ts (ArkType). Server-side only.

# Supabase Postgres connection string.
# Dashboard → Project → Connect → ORMs (Drizzle). Use the Transaction pooler URL.
# postgres-js is configured with prepare:false to work with the pooler.
DATABASE_URL=

# Better Auth (set up in a later chunk). Generate a secret with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Resend — email connector (set up in a later chunk). https://resend.com/api-keys
RESEND_API_KEY=
